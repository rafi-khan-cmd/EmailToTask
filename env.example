# Optional environment variables for local development.
#
# Streamlit will load environment variables from your shell.

# Where the SQLite DB file should be stored.
# If not set, the app will use a writable directory in your home folder.
EMAIL_TO_TASK_DATA_DIR=

# Default extractor method: `rule_based` or `spacy`
EMAIL_TO_TASK_EXTRACTOR_METHOD=spacy
